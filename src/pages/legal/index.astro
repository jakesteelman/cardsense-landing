---
import LegalLayout from "../../layouts/LegalLayout.astro";

const docs = [
  {
    title: "Privacy Policy",
    href: "/legal/privacy",
    blurb:
      "What we collect, what stays on your device, and how your data is handled.",
  },
  {
    title: "Terms of Service",
    href: "/legal/terms",
    blurb: "The terms that govern your use of the Cardsense app and website.",
  },
  {
    title: "Disclaimer",
    href: "/legal/disclaimer",
    blurb:
      "Cardsense provides general information about card benefits — not financial advice.",
  },
];

const frontmatter = {
  title: "Legal",
  description: "Cardsense legal documents — privacy, terms, and disclaimer.",
};
---

<LegalLayout frontmatter={frontmatter}>
  <p class="text-ink-65 text-center">
    The documents below govern your use of Cardsense. Questions? Reach us at
    <a href="mailto:legal@cardsense.app">legal@cardsense.app</a>.
  </p>

  <div class="not-prose grid gap-3 sm:grid-cols-1 mt-8" style="margin-top:2rem">
    {
      docs.map((d) => (
        <a
          href={d.href}
          class="card group flex items-center justify-between gap-6 px-6 py-5 no-underline transition-shadow hover:shadow-card-lg"
        >
          <span>
            <span class="block font-tight font-semibold text-[17px] text-ink tracking-[-0.02em]">
              {d.title}
            </span>
            <span class="block mt-1 text-[14px] text-ink-60 leading-[1.5]">
              {d.blurb}
            </span>
          </span>
          <svg
            class="shrink-0 text-ink-40 group-hover:text-ink transition-colors"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      ))
    }
  </div>
</LegalLayout>
