---
const steps = [
  {
    n: '1',
    title: 'Add your cards',
    body: 'Pick your cards from a list of supported issuers. No bank login, no account linking — just pick and you\'re in.',
    icon: 'M12 4v16m8-8H4',
  },
  {
    n: '2',
    title: 'See your whole year',
    body: 'Every credit, perk, and annual fee laid out so you can see exactly what each card owes you and when it resets.',
    icon: 'M3 9a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V9zm0 0V5a2 2 0 012-2h14a2 2 0 012 2v4M8 3v4m8-4v4',
  },
  {
    n: '3',
    title: 'Get notified before it\'s too late',
    body: "Cardsense sends a reminder a few days before any credit resets to zero, and lets you know when you're near a place where one of your cards earns more.",
    icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0',
  },
] as const;
---
<section id="how" class="relative mx-auto max-w-5xl px-6 pt-[60px] pb-[100px]">
  <div class="text-center mb-14">
    <h2
      class="font-tight font-semibold tracking-[-0.035em] leading-[1.02] m-0 text-ink"
      style="font-size:clamp(36px,4.5vw,56px)"
    >
      30 seconds to set up.
    </h2>
  </div>

  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px">
    {steps.map(({ n, title, body, icon }) => (
      <div class="card flex flex-col gap-3.5 p-7">
        <div class="flex items-center justify-between">
          <div class="text-[13px] font-medium text-ink-50 tracking-[-0.005em] tabular-nums">
            Step {n}
          </div>
          <div class="flex items-center justify-center w-9 h-9 rounded-[10px] bg-muted text-ink">
            <svg width={18} height={18} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d={icon} />
            </svg>
          </div>
        </div>
        <h3 class="font-tight font-semibold text-[22px] tracking-[-0.025em] leading-[1.15] m-0">
          {title}
        </h3>
        <p class="text-[15px] text-ink-65 leading-[1.5] m-0 tracking-[-0.005em]">
          {body}
        </p>
      </div>
    ))}
  </div>
</section>
