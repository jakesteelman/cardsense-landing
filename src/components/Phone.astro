---
interface Props { h?: number; class?: string }
const { h = 640 } = Astro.props;
const w = h * 0.495;
const br = h * 0.075;
const innerBr = h * 0.06;
const diW = w * 0.32;
---
<div style={`position:relative;width:${w}px;height:${h}px`}>
  <div style={`
    width:${w}px;height:${h}px;
    border-radius:${br}px;
    background:linear-gradient(140deg,#2a2a2c 0%,#0a0a0c 50%,#1a1a1c 100%);
    padding:8px;box-sizing:border-box;position:relative;
    box-shadow:0 50px 90px -20px rgba(0,0,0,0.25),0 25px 50px -15px rgba(0,0,0,0.18),inset 0 0 0 1.5px rgba(255,255,255,0.08),inset 0 2px 0 rgba(255,255,255,0.1);
  `}>
    <div style={`
      width:100%;height:100%;border-radius:${innerBr}px;
      background:radial-gradient(ellipse at 30% 20%,#1a1a1f 0%,#050506 70%);
      position:relative;overflow:hidden;
    `}>
      <!-- Dynamic Island -->
      <div style={`
        position:absolute;top:14px;left:50%;transform:translateX(-50%);
        width:${diW}px;height:28px;background:#000;border-radius:20px;
        box-shadow:inset 0 0 0 0.5px rgba(255,255,255,0.04);
      `}></div>
      <!-- Screen highlight -->
      <div style="
        position:absolute;top:0;left:0;right:0;height:45%;
        background:linear-gradient(160deg,rgba(255,255,255,0.04),transparent 60%);
        pointer-events:none;
      "></div>
    </div>
    <!-- Side buttons -->
    <div style="position:absolute;left:-2px;top:20%;width:2px;height:60px;background:linear-gradient(90deg,rgba(255,255,255,0.12),transparent);border-radius:2px;"></div>
    <div style="position:absolute;right:-2px;top:28%;width:2px;height:80px;background:linear-gradient(270deg,rgba(255,255,255,0.12),transparent);border-radius:2px;"></div>
  </div>
</div>
