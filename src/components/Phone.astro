---
interface Props {
  h?: number;
  screenshot?: string;
}
const { h = 640, screenshot } = Astro.props;
const aspectRatio = 1350 / 2760;
const w = Math.round(h * aspectRatio);
const r = Math.round(w * 0.1);
---
<div style={`position:relative;width:${w}px;height:${h}px;flex-shrink:0;`}>
  {screenshot && (
    <div style={`position:absolute;top:2.39%;left:5.41%;right:5.19%;bottom:2.43%;clip-path:inset(0 0 0 0 round ${r}px);`}>
      <img
        src={screenshot}
        alt=""
        aria-hidden="true"
        style="width:100%;height:100%;object-fit:cover;object-position:top center;display:block;"
      />
    </div>
  )}
  <img
    src="/iphone-17-pro-bezel.png"
    alt=""
    aria-hidden="true"
    width={w}
    height={h}
    style={`position:absolute;top:0;left:0;width:${w}px;height:${h}px;display:block;`}
  />
</div>
