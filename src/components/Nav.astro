---
import Logo from './Logo.astro';
interface Props { mode: 'waitlist' | 'download' }
const { mode } = Astro.props;
const isWaitlist = mode === 'waitlist';

const links = [
  ['Features', '#features'],
  ['How it works', '#how'],
  ['Pricing', '#pricing'],
  ['FAQ', '#faq'],
] as const;
---
<nav class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-max max-w-[calc(100vw-32px)]">
  <div class="glass-pill flex items-center gap-1 rounded-full py-2 pl-[18px] pr-2">
    <a
      href="#"
      class="flex items-center gap-2 no-underline font-semibold mr-2 whitespace-nowrap text-ink text-[16.5px] tracking-[-0.015em]"
    >
      <Logo size={28} appIcon={true} />
      <span>Cardsense</span>
    </a>

    <div class="flex items-center gap-0.5 text-[14px] text-ink-65">
      {links.map(([label, href]) => (
        <a
          href={href}
          class="nav-link rounded-full no-underline whitespace-nowrap px-[13px] py-[7px] text-ink-65 transition-[background,color] duration-150"
        >
          {label}
        </a>
      ))}
    </div>

    <a
      href="#download"
      class="inline-flex items-center gap-1.5 rounded-full no-underline font-semibold whitespace-nowrap ml-2 px-4 py-2 bg-ink text-white text-[14px] tracking-[-0.005em]"
    >
      {isWaitlist ? 'Join waitlist' : 'Download'}
    </a>
  </div>
</nav>

<script>
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('mouseenter', () => {
      (link as HTMLElement).style.background = 'rgba(10,10,10,0.05)';
      (link as HTMLElement).style.color = 'var(--ink)';
    });
    link.addEventListener('mouseleave', () => {
      (link as HTMLElement).style.background = 'transparent';
      (link as HTMLElement).style.color = 'var(--ink-65)';
    });
  });
</script>
