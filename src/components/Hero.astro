---
import Phone from "./Phone.astro";
import EmailForm from "./EmailForm";
interface Props {
  mode: "waitlist" | "download";
}
const { mode } = Astro.props;
const isWaitlist = mode === "waitlist";
---

<section
  class="relative mx-auto text-center max-w-5xl px-6 pt-[140px] pb-[60px]"
>
  <!-- Chip -->
  <!-- <div
    class="tag inline-flex items-center gap-2 rounded-full px-[14px] py-[6px] text-[13px] text-ink-65 font-medium mb-7 tracking-[-0.005em]"
  >
    <span class="rounded-full w-1.5 h-1.5 bg-accent"></span>
    {isWaitlist ? "Coming to iPhone" : "Now on iPhone"}
  </div> -->

  <!-- Headline -->
  <div class="max-w-xl mx-auto">
    <h1 class="font-tight text-7xl font-semibold tracking-tight text-ink">
      The OS for Your Credit Cards
    </h1>
    <p
      class="text-ink-65 text-lg mx-auto mt-7 mb-9 leading-[1.5] tracking-[-0.005em]"
    >
      Keep track of every credit, perk, and annual fee across all your cards —
      and always know which card to pull before you tap.
    </p>
    {
      isWaitlist ? (
        <div class="mb-[70px]">
          <EmailForm
            client:load
            size="lg"
            placeholder="you@email.com"
            btn="Join waitlist"
            style={{ maxWidth: 460, margin: "0 auto" }}
          />
          <p class="text-[13.5px] text-ink-50 mt-3 mb-0 tracking-[-0.005em]">
            We'll email you the day it ships. Nothing else.
          </p>
        </div>
      ) : (
        <div class="flex gap-2.5 justify-center flex-wrap mb-20">
          <a
            href="#download"
            class="inline-flex items-center gap-2 rounded-full no-underline font-semibold px-6 py-[13px] bg-ink text-white text-[15px] tracking-[-0.005em] shadow-[0_6px_18px_rgba(0,0,0,0.18),inset_0_1px_0_rgba(255,255,255,0.12)]"
          >
            Download for iPhone
            <svg
              width={16}
              height={16}
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
          <a
            href="#how"
            class="btn-outline inline-flex items-center gap-2 rounded-full no-underline font-semibold px-6 py-[13px] text-ink text-[15px] tracking-[-0.005em]"
          >
            See how it works
          </a>
        </div>
      )
    }
  </div>

  <!-- Phone -->
  <div class={`flex justify-center${isWaitlist ? " mt-[50px]" : ""}`}>
    <Phone h={680} screenshot="/home.png" />
  </div>
</section>
