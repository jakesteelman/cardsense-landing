---
interface Props {
  big?: boolean;
  visibleH?: number;
  screenshot?: string;
}
const { big = false, visibleH: visibleHProp, screenshot } = Astro.props;

const aspectRatio = 2760 / 1350;
const w = big ? 357 : 267;
const h = Math.round(w * aspectRatio);
const visibleH = visibleHProp ?? (big ? 460 : 300);
const r = Math.round(w * 0.1);

// All insets in px relative to full phone dimensions (h, w)
const sTop   = Math.round(h * 0.0239);
const sLeft  = Math.round(w * 0.0541);
const sRight = Math.round(w * 0.0519);
// bottom CSS value = visibleH - (full phone height - bottom inset px)
// will be negative → screenshot extends below clip boundary, overflow:hidden clips it
const sBottom = visibleH - (h - Math.round(h * 0.0243));
---
<div style={`position:relative;width:${w}px;height:${visibleH}px;overflow:hidden;flex-shrink:0;`}>
  {screenshot && (
    <div style={`position:absolute;top:${sTop}px;left:${sLeft}px;right:${sRight}px;bottom:${sBottom}px;clip-path:inset(0 0 0 0 round ${r}px ${r}px 0 0);`}>
      <img
        src={screenshot}
        alt=""
        aria-hidden="true"
        style="width:100%;height:100%;object-fit:cover;object-position:top center;display:block;"
      />
    </div>
  )}
  <img
    src="/iphone-17-pro-bezel.png"
    alt=""
    aria-hidden="true"
    width={w}
    height={h}
    style={`position:absolute;top:0;left:0;width:${w}px;height:${h}px;display:block;`}
  />
</div>
